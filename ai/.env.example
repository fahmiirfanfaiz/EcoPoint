# ============================================================
# EcoPoint AI Service — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# ------------------------------------------------------------
# Google Gemini API Key
# Dapatkan dari: https://aistudio.google.com/app/apikey
# Kedua nama env var didukung (kompatibilitas)
# ------------------------------------------------------------
GEMINI_API_KEY="your-google-gemini-api-key"
# atau (nama alternatif):
# GOOGLE_API_KEY="your-google-gemini-api-key"

# ------------------------------------------------------------
# AI Service Internal API Key
# String acak yang digunakan sebagai "password" untuk mengamankan
# endpoint FastAPI ini. Harus sama persis dengan nilai
# AI_SERVICE_API_KEY di .env Frontend dan Backend.
# Kirim via header: X-API-Key: <nilai ini>
# ------------------------------------------------------------
AI_SERVICE_API_KEY="your-ai-service-api-key"

# ============================================================
# URL Service (untuk referensi, tidak dibaca langsung oleh kode)
# ============================================================
# AI Service berjalan di:
#   Lokal:      http://localhost:8000
#   Production: https://ecopoint-ai-dqfhgxbbb6f8fafv.southeastasia-01.azurewebsites.net
