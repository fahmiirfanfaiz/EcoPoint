# ============================================================
# EcoPoint Frontend — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# ------------------------------------------------------------
# Supabase (Database & Storage)
# Dapatkan dari: https://supabase.com → Project Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
SUPABASE_SECRET_KEY="your-supabase-service-role-secret-key"

# ------------------------------------------------------------
# S3-Compatible Storage (Supabase Storage S3 API)
# Dapatkan dari: Supabase → Storage → S3 Access
# ------------------------------------------------------------
S3_ENDPOINT="https://<your-project-ref>.supabase.co/storage/v1/s3"
S3_ACCESS_KEY_ID="your-s3-access-key-id"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"
S3_REGION="ap-southeast-1"
S3_BUCKET="your-bucket-name"

# ------------------------------------------------------------
# SSL Certificate (untuk koneksi database jika diperlukan)
# ------------------------------------------------------------
SSL_CA="-----BEGIN CERTIFICATE-----
<your-ssl-certificate-content>
-----END CERTIFICATE-----"

# ------------------------------------------------------------
# Backend API URL
# Pilih SALAH SATU: komentari yang tidak digunakan
# ------------------------------------------------------------
# Lokal (development):
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api"
# Production (Vercel):
# NEXT_PUBLIC_API_BASE_URL="https://api-ecopoint.vercel.app/api"

# ------------------------------------------------------------
# AI Service
# Pilih SALAH SATU: komentari yang tidak digunakan
# ------------------------------------------------------------
# Lokal (development):
AI_SERVICE_URL="http://localhost:8000/"
# Production (Azure App Service):
# AI_SERVICE_URL="https://ecopoint-ai-dqfhgxbbb6f8fafv.southeastasia-01.azurewebsites.net/"

# API Key untuk autentikasi ke AI Service (harus sama dengan AI .env)
AI_SERVICE_API_KEY="your-ai-service-api-key"
