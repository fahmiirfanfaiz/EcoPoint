generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model badges {
  badges_id    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama_badge   String        @unique
  deskripsi    String
  syarat_poin  BigInt        @default(0)
  jenis_syarat String        @default("TOTAL_POIN")
  nilai_syarat BigInt        @default(0)
  user_badges  user_badges[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notifications {
  notifications_id String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String   @db.Uuid
  pesan            String
  is_read          Boolean  @default(false)
  created_at       DateTime @default(now()) @db.Timestamp(6)
  endpoint         String   @unique
  p256dh           String
  auth             String
  device           String
  users            users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([notifications_id, user_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model redemptions {
  redemption_id  String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  reward_id      String   @db.Uuid
  poin_digunakan BigInt
  redeemed_at    DateTime @default(now()) @db.Timestamp(6)
  rewards        rewards  @relation(fields: [reward_id], references: [reward_id])
  users          users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([redemption_id, user_id, reward_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model rewards {
  reward_id       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama_reward     String        @unique
  deskripsi       String
  poin_dibutuhkan BigInt
  stok            BigInt        @default(0)
  is_active       Boolean       @default(true)
  redemptions     redemptions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_badges {
  user_id   String   @db.Uuid
  badges_id String   @db.Uuid
  earned_at DateTime @default(now()) @db.Timestamp(6)
  badges    badges   @relation(fields: [badges_id], references: [badges_id])
  users     users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([user_id, badges_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model waste_reports {
  report_id       BigInt   @default(autoincrement())
  user_id         String   @db.Uuid
  foto_url        String
  kategori_user   String
  kategori_ai     String?
  status_validasi String   @default("'pending'")
  poin_didapat    BigInt   @default(8)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  users           users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([report_id, user_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  user_id               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama                  String
  nim                   String                  @unique
  password              String                  @default("")
  total_poin            BigInt                  @default(0)
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  role                  String                  @default("'mahasiswa'")
  email                 String                  @unique
  fakultas              String                  @default("")
  notifications         notifications[]
  redemptions           redemptions[]
  user_badges           user_badges[]
  user_daily_challenges user_daily_challenges[]
  waste_reports         waste_reports[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model challenge_of_the_day {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challenge_id          String                  @db.Uuid
  tanggal               DateTime                @db.Date
  daily_challenges      daily_challenges        @relation(fields: [challenge_id], references: [challenge_id], onDelete: Cascade, onUpdate: NoAction)
  user_daily_challenges user_daily_challenges[]

  @@unique([challenge_id, tanggal], map: "unique_challenge_date")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model daily_challenges {
  challenge_id         String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama_challenge       String
  deskripsi            String
  poin_hadiah          BigInt                 @default(0)
  target_count         BigInt                 @default(1)
  challenge_type       String
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  is_permanent         Boolean                @default(false)
  challenge_of_the_day challenge_of_the_day[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_daily_challenges {
  user_daily_challenges_id String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                  String               @db.Uuid
  challenge_of_the_day_id  String               @db.Uuid
  current_progress         BigInt               @default(0)
  is_completed             Boolean              @default(false)
  is_points_claimed        Boolean              @default(false)
  claimed_at               DateTime?            @db.Timestamp(6)
  challenge_of_the_day     challenge_of_the_day @relation(fields: [challenge_of_the_day_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_daily_challenges_challenge_fkey")
  users                    users                @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, challenge_of_the_day_id], map: "unique_user_daily_challenge")
}

/// Leveling system — admin-configurable levels based on lifetime points
model levels {
  level_id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level_number Int      @unique
  nama_level   String
  syarat_poin  BigInt   @default(0)
  created_at   DateTime @default(now()) @db.Timestamp(6)
}
