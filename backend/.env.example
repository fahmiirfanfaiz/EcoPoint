# ============================================================
# EcoPoint Backend — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# ------------------------------------------------------------
# Database (Supabase PostgreSQL)
# Dapatkan dari: https://supabase.com → Project Settings → Database
# ------------------------------------------------------------
# Connection pooling — digunakan oleh Prisma Client (runtime)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — digunakan untuk migrasi Prisma
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------
# Gunakan string acak yang panjang dan aman (min. 32 karakter)
JWT_SECRET="your-super-secret-jwt-key-here"

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=4000

# ------------------------------------------------------------
# Google OAuth (jika digunakan)
# Pilih SALAH SATU: komentari yang tidak digunakan
# ------------------------------------------------------------
# Lokal (development):
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"
# Production (Vercel):
# GOOGLE_CALLBACK_URL="https://api-ecopoint.vercel.app/api/auth/google/callback"
